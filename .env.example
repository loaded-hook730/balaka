#
# FastAPI runtime
#
BALAKA_DEBUG=false

#
# Local TTS runtime
# Preload is enabled so the model is loaded at startup instead of on the first TTS request.
# ASR is disabled because normal voice cloning in this project requires explicit reference_text.
#
BALAKA_TTS_MODEL=k2-fsa/OmniVoice
BALAKA_TTS_DEVICE=auto
BALAKA_TTS_DTYPE=auto
BALAKA_TTS_PRELOAD_RUNTIME=true
BALAKA_TTS_LOAD_ASR=false
